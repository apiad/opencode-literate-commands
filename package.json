{
  "name": "opencode-literate-commands",
  "version": "1.0.0",
  "description": "OpenCode plugin for step-by-step command execution from markdown",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vitest"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "cli",
    "markdown",
    "literate"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/apiad/opencode-literate-commands.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.10",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
