{
  "name": "opencode-literate-commands",
  "version": "1.0.0",
  "description": "OpenCode plugin for step-by-step command execution from markdown",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "esbuild index.ts --bundle --format=esm --outfile=literate-commands.js --platform=node",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist/",
    "literate-commands.js",
    "examples/"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "cli",
    "markdown",
    "literate"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/apiad/opencode-literate-commands.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.27.4",
    "vitest": "^1.2.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  }
}
